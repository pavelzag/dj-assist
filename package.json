{
  "name": "dj-assist",
  "version": "0.5.9",
  "private": true,
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "predev": "node scripts/check-node.cjs",
    "dev": "node scripts/electron-dev.cjs",
    "backend:dev": "rm -rf .next && next dev",
    "electron:dev": "node scripts/check-node.cjs && node scripts/electron-dev.cjs",
    "prepare:build-env": "node scripts/prepare-build-env.cjs",
    "prepare:audio-tools": "node scripts/prepare-audio-tools.cjs",
    "prepare:python-bundle": "node scripts/prepare-python-bundle.cjs",
    "prepare:standalone-assets": "node scripts/prepare-standalone-assets.cjs",
    "verify:google-oauth": "node scripts/verify-google-oauth.cjs",
    "verify:google-oauth-config": "node scripts/verify-google-oauth-config.cjs",
    "prebuild": "node scripts/check-node.cjs",
    "build": "next build",
    "dist:mac": "npm run prepare:build-env && npm run build && npm run prepare:standalone-assets && npm run prepare:python-bundle && npm run prepare:audio-tools && electron-builder --mac dmg zip",
    "pack:mac": "npm run prepare:build-env && npm run build && npm run prepare:standalone-assets && npm run prepare:python-bundle && npm run prepare:audio-tools && electron-builder --mac dir",
    "prestart": "node scripts/check-node.cjs",
    "start": "node scripts/electron-start.cjs",
    "backend:start": "next start",
    "electron:start": "node scripts/check-node.cjs && node scripts/electron-start.cjs"
  },
  "dependencies": {
    "jose": "^6.2.2",
    "next": "^15.3.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "41.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.djassist.desktop",
    "productName": "DJ Assist",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asar": false,
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron/assets"
    },
    "afterSign": "scripts/notarize-mac.cjs",
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "dj_assist/**/*",
      "requirements.txt",
      "pyproject.toml",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "audio-tools",
        "to": "audio-tools",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "category": "public.app-category.music",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/assets/app-icon.png"
    }
  }
}
